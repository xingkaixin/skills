---
import type { SkillRecord } from "@/data/skill-record";

interface Props {
  skills: SkillRecord[];
  categories: string[];
}

const { skills, categories } = Astro.props;
const chipBase = "rounded-full border px-3 py-1 text-xs uppercase tracking-[0.16em] transition";
const chipActive = "border-text bg-text text-white";
const chipInactive = "border-border bg-transparent text-text-secondary hover:border-text hover:text-text";
---

<div data-skill-filter>
  <div class="sticky top-0 z-10 -mx-6 px-6 py-3 bg-bg border-b border-border flex flex-wrap items-center gap-2 mb-6">
    <button
      type="button"
      class={`${chipBase} ${chipActive}`}
      data-category="all"
      aria-pressed="true"
    >
      All
    </button>
    {categories.map((category) => (
      <button
        type="button"
        class={`${chipBase} ${chipInactive}`}
        data-category={category}
        aria-pressed="false"
      >
        {category}
      </button>
    ))}
    <span class="ml-auto text-xs text-text-muted" data-skill-count>{skills.length} skills</span>
  </div>

  <div class="divide-y divide-border">
    {skills.map((skill) => (
      <a
        href={`/skills/${skill.slug}`}
        class="flex items-baseline gap-6 py-3 px-1 transition-colors hover:bg-accent-soft group"
        data-skill-item
        data-category={skill.category}
      >
        <span class="w-44 shrink-0 font-medium text-sm text-text truncate">
          {skill.slug}
        </span>
        <span class="flex-1 min-w-0 text-sm text-text-secondary truncate">
          {skill.description}
        </span>
        <span class="text-xs text-text-muted shrink-0 opacity-0 group-hover:opacity-100 transition-opacity">
          -&gt;
        </span>
      </a>
    ))}
  </div>
</div>

<script>
  const root = document.querySelector("[data-skill-filter]");

  if (root instanceof HTMLElement) {
    const buttons = Array.from(root.querySelectorAll("button[data-category]"));
    const items = Array.from(root.querySelectorAll("[data-skill-item]"));
    const count = root.querySelector("[data-skill-count]");
    const knownCategories = new Set(
      buttons.map((button) => button.getAttribute("data-category")),
    );
    const activeClasses = ["border-text", "bg-text", "text-white"];
    const inactiveClasses = [
      "border-border",
      "bg-transparent",
      "text-text-secondary",
      "hover:border-text",
      "hover:text-text",
    ];

    function setButtonState(button, isActive) {
      button.classList.remove(...activeClasses, ...inactiveClasses);
      button.classList.add(...(isActive ? activeClasses : inactiveClasses));
      button.setAttribute("aria-pressed", isActive ? "true" : "false");
    }

    function applyFilter(category, updateUrl) {
      let visibleCount = 0;

      for (const item of items) {
        const isVisible =
          category === "all" || item.getAttribute("data-category") === category;
        item.toggleAttribute("hidden", !isVisible);
        if (isVisible) visibleCount += 1;
      }

      for (const button of buttons) {
        setButtonState(button, button.getAttribute("data-category") === category);
      }

      if (count) {
        count.textContent = `${visibleCount} skills`;
      }

      if (updateUrl) {
        const url = new URL(window.location.href);
        if (category === "all") {
          url.searchParams.delete("category");
        } else {
          url.searchParams.set("category", category);
        }
        window.history.replaceState({}, "", `${url.pathname}${url.search}${url.hash}`);
      }
    }

    const initialCategory = new URLSearchParams(window.location.search).get("category");
    applyFilter(
      initialCategory && knownCategories.has(initialCategory) ? initialCategory : "all",
      false,
    );

    for (const button of buttons) {
      button.addEventListener("click", () => {
        applyFilter(button.getAttribute("data-category") ?? "all", true);
      });
    }
  }
</script>
