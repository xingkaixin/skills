---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteBrand from "@/components/SiteBrand.astro";
import SkillFilter from "@/components/SkillFilter.astro";
import { SITE_REPO } from "@/data/catalog";
import { getSkills, getSkillTags } from "@/data/skills";
import { getHomeSeo } from "@/data/seo";
import { faqItems } from "@/data/faq";

const skills = getSkills();
const tags = getSkillTags();
const seo = getHomeSeo();
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonicalUrl={seo.canonicalUrl}
  ogType={seo.ogType}
  structuredData={seo.structuredData}
>
  <div class="min-h-screen">
    <nav class="border-b border-border px-6 py-4">
      <div class="mx-auto flex max-w-5xl items-center justify-between gap-6">
        <SiteBrand />
        <a
          href={SITE_REPO}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-md border border-border px-3 py-1.5 text-xs text-text-secondary transition hover:border-text hover:text-text"
        >
          GitHub
        </a>
      </div>
    </nav>

    <div class="border-b border-border px-6 py-2">
      <div class="mx-auto max-w-5xl">
        <p class="text-xs text-text-muted">
          xingkaixin&nbsp;/&nbsp;<span class="text-text-secondary font-medium">skills</span>
        </p>
      </div>
    </div>

    <main class="mx-auto max-w-5xl px-6 pb-20 pt-8">
      <h1 class="font-semibold text-xl text-text">xingkaixin/skills</h1>
      <p class="mt-1.5 text-sm text-text-secondary">Agent skills for AI Agents</p>

      <div class="mt-8 space-y-4">
        <p class="text-xs uppercase tracking-[0.18em] text-text-muted">Usage</p>

        <div>
          <p class="mb-1.5 text-xs text-text-muted">Install all skills</p>
          <div class="inline-flex items-center rounded-md border border-border bg-[#f6f8fa] px-4 py-2.5">
            <code class="font-mono text-sm text-text">npx skills add xingkaixin/skills</code>
          </div>
        </div>

        <div>
          <p class="mb-1.5 text-xs text-text-muted">Install a single skill</p>
          <div class="inline-flex items-center rounded-md border border-border bg-[#f6f8fa] px-4 py-2.5">
            <code class="font-mono text-sm text-text">npx skills add xingkaixin/skills --skill agent-dump</code>
          </div>
        </div>
      </div>

      <hr class="my-8 border-border" />

      <SkillFilter skills={skills} tags={tags} />

      <hr class="my-12 border-border" />

      <section aria-labelledby="faq-heading">
        <h2 id="faq-heading" class="font-semibold text-lg text-text">FAQ</h2>
        <dl class="mt-6 space-y-6">
          {faqItems.map((item) => (
            <div>
              <dt class="text-sm font-medium text-text">{item.question}</dt>
              <dd class="mt-1.5 text-sm leading-7 text-text-secondary">{item.answer}</dd>
            </div>
          ))}
        </dl>
      </section>
    </main>
  </div>
</BaseLayout>
