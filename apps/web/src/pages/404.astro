---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE_URL } from "@/data/catalog";

const title = "404 - XingKaiXin's Skills";
const description = "Page not found.";
---

<BaseLayout
  title={title}
  description={description}
  canonicalUrl={`${SITE_URL}/404`}
  noindex
>
  <main class="min-h-screen flex items-center justify-center">
    <div class="text-center">
      <h1 class="text-2xl font-semibold">404</h1>
      <p class="mt-2 text-text-secondary">Page not found</p>
      <a href="/" class="mt-4 inline-block text-sm text-text-secondary hover:text-text underline">
        Back to catalog
      </a>
    </div>
  </main>
</BaseLayout>
